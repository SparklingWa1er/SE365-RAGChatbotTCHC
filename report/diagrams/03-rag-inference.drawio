        <mxCell id="ds_ret" value="docsearch → HYBRID retrieve:&#10;Chroma (vector) + LanceDB (BM25)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
