          <mxGeometry x="120" y="628" width="160" height="66" as="geometry" />
        </mxCell>
        <mxCell id="ds_emit" value="emit() nguồn liên quan → collected_docs (dedup)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="728" width="260" height="44" as="geometry" />
        </mxCell>
        <mxCell id="dec_more" value="Đủ nguồn hoặc&#10;hết vòng lặp?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="1">
