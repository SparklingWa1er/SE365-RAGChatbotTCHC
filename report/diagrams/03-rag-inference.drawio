          <mxGeometry x="430" y="1410" width="300" height="52" as="geometry" />
        </mxCell>

        <!-- output -->
        <mxCell id="end" value="Stream câu trả lời (SSE) + panel Nguồn 【n】 + Mindmap → người dùng" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="1538" width="340" height="50" as="geometry" />
        </mxCell>

        <!-- NOTES -->
        <mxCell id="n_decomp" value="Fan-out: mỗi câu con tra riêng rồi dồn nguồn&#10;vào CHUNG collected_docs → phủ hết khía cạnh&#10;(hồ sơ / thời hạn / lệ phí / cơ quan...)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="980" y="236" width="300" height="86" as="geometry" />
        </mxCell>
        <mxCell id="n_web" value="WEB FALLBACK: chỉ dùng khi corpus nội bộ&#10;thiếu. Kết quả gắn 🌐 + điểm thấp 0.2 (chưa&#10;thẩm định) để không lấn nguồn chính thống;&#10;fetch nội dung trang để có chi tiết cụ thể." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="980" y="420" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n_gate" value="★ CƠ CHẾ CORRECTIVE-RAG (relevance_floor = 0.5):&#10;nếu điểm LLM-rerank cao nhất &lt; 0.5 → coi corpus&#10;KHÔNG có đáp án tin cậy → trả NO_RELEVANT để&#10;agent đổi từ khóa hoặc chuyển sang web, và KHÔNG&#10;emit nguồn lạc đề. (đáp đúng ~0.8–0.9, nhiễu ~0.2–0.3)&#10;E2: chặn lặp y hệt truy vấn để khỏi phí vòng lặp." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="980" y="560" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n_simple" value="(Đường thay thế) Chế độ 'Trả lời nhanh'&#10;FullQAPipeline — 1 lượt, KHÔNG vòng lặp agent:&#10;viết lại truy vấn → hybrid retrieve → rerank lọc&#10;điểm 0 → nếu rỗng trả 'ngoài phạm vi' → synthesis." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="980" y="958" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n_assemble" value="Nhóm theo THỦ TỤC + kéo đủ phần thủ tục&#10;mạnh (≥ 0.6, tối đa 4) → synthesis trình bày&#10;TÁCH BẠCH từng thủ tục, tránh trộn lẫn&#10;(&quot;Frankenstein&quot;) các thủ tục khác nhau." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="980" y="1126" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="n_cite" value="Trích dẫn TRUY VẾT: mỗi ý gắn 【n】 → span&#10;tài liệu nguồn; bấm 【n】 ở UI mở panel Nguồn&#10;đúng đoạn. Quyết định từ chối/cảnh báo do CODE&#10;dựa trên điểm rerank, không phó mặc LLM bịa." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="980" y="1380" width="300" height="100" as="geometry" />
