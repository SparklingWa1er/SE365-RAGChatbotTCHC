<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="rag-inference" name="RAG - Suy luan">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1320" pageHeight="1640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="QUÁ TRÌNH SUY LUẬN LLM / RAG — ReAct Agent (Corrective-RAG)&#10;ktem/reasoning/react.py — 2 pha: GOM NGUỒN (agent) → TỔNG HỢP có trích dẫn" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="14" width="900" height="46" as="geometry" />
        </mxCell>

        <!-- containers -->
        <mxCell id="cP1" value="PHA 1 — ReAct AGENT GOM NGUỒN (lặp Thought / Action / Observation cho TỪNG câu hỏi con)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673A6;dashed=1;verticalAlign=top;fontStyle=1;fontColor=#9673A6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="332" width="840" height="588" as="geometry" />
        </mxCell>
        <mxCell id="cP2" value="PHA 2 — TỔNG HỢP CÂU TRẢ LỜI CÓ INLINE CITATION (synthesis)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6C8EBF;dashed=1;verticalAlign=top;fontStyle=1;fontColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="948" width="840" height="560" as="geometry" />
        </mxCell>

        <!-- pre-phase -->
        <mxCell id="start" value="Câu hỏi người dùng  +  lịch sử hội thoại" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="78" width="300" height="42" as="geometry" />
        </mxCell>
        <mxCell id="ctx" value="Contextualize (chỉ khi có lịch sử):&#10;giải tham chiếu ngầm → câu hỏi ĐỘC LẬP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="158" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="decomp" value="Phase-0 Decompose: tách câu hỏi phức&#10;thành ≤ 4 câu hỏi con độc lập (fan-out)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;" vertex="1" parent="1">
