          <mxGeometry x="700" y="464" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="web" value="web_search (Brave) — FALLBACK:&#10;fetch top trang → bọc RetrievedDocument&#10;(nhãn 🌐, điểm 0.2) → emit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4D6;strokeColor=#E07A2F;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="540" width="300" height="64" as="geometry" />
        </mxCell>
        <mxCell id="ds_gate" value="Relevance gate:&#10;điểm LLM-rerank (Trulens)&#10;cao nhất ≥ 0.5?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="305" y="618" width="250" height="86" as="geometry" />
