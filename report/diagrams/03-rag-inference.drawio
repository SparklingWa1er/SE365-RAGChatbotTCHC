        <mxCell id="e_gate_emit" value="≥ 0.5  (Có)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="ds_gate" target="ds_emit"><mxGeometry relative="1" as="geometry" /></mxCell>
