        <mxCell id="e_more_loop" value="Chưa đủ → Action kế" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="dec_more" target="thought">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="900" y="836" /><mxPoint x="900" y="392" /></Array></mxGeometry>
