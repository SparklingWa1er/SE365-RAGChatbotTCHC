        <mxCell id="fallback" value="Trả lời fallback:&#10;chưa tìm thấy / chào hỏi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="1044" width="180" height="62" as="geometry" />
        </mxCell>
        <mxCell id="s_assemble" value="assemble_by_procedure: nhóm nguồn theo THỦ TỤC&#10;+ kéo ĐỦ các phần của thủ tục mạnh (≥ 0.6) từ docstore" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="1132" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cyl_docstore" value="docstore&#10;(kéo đủ phần)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="130" y="1138" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="s_names" value="apply_friendly_names: id file → tên thủ tục" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="1212" width="300" height="38" as="geometry" />
        </mxCell>
        <mxCell id="s_evid" value="PrepareEvidencePipeline → evidence&#10;(ghép ngữ cảnh, cắt theo max_context_length)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="1270" width="300" height="48" as="geometry" />
        </mxCell>
        <mxCell id="s_answer" value="AnswerWithInlineCitation (LLM):&#10;sinh CITATION LIST + chèn 【n】 vào câu trả lời" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="1338" width="300" height="52" as="geometry" />
