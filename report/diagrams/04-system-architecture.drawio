        <!-- NOTES -->
        <mxCell id="n_online" value="ONLINE: mỗi câu hỏi được stream token thời&#10;gian thực qua SSE. Lịch sử hội thoại, bước suy&#10;luận và nguồn trích dẫn được lưu theo từng lượt.&#10;Người dùng đổi chế độ trong ModeSelect:&#10;Suy luận sâu (ReAct) ↔ Trả lời nhanh." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="1100" y="100" width="290" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n_offline" value="OFFLINE: chạy theo mẻ khi dựng index hoặc cập&#10;nhật dữ liệu — TÁCH RỜI khỏi serving. Crawler resume&#10;được; ingest song song ~15 phút cho 5.208 thủ tục." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="724" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="n_storage" value="HYBRID: Chroma (vector) + LanceDB (BM25) phục vụ truy hồi; rerank bằng LLM trước khi trả lời. sql.db lưu cả quan hệ index lẫn hội thoại; files giữ bản .md gốc để trích dẫn." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
