        <mxCell id="title" value="KIẾN TRÚC &amp; HOẠT ĐỘNG TOÀN HỆ THỐNG — Chatbot RAG Thủ tục hành chính công&#10;Pipeline dữ liệu (offline) ·  Kho lưu trữ (chia sẻ)  ·  Ứng dụng trực tuyến (online)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fillColor=none;" vertex="1" parent="1">
