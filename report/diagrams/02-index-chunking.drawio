        <mxCell id="e14" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;startArrow=block;endArrow=block;dashed=1;strokeColor=#B85450;fontSize=10;" edge="1" parent="1" source="i_embed" target="ext_azure"><mxGeometry relative="1" as="geometry" /></mxCell>
