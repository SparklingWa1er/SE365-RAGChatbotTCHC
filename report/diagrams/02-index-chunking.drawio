        <mxCell id="e17" value="mỗi batch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;dashed=1;strokeColor=#D79B00;fontSize=10;" edge="1" parent="1" source="i_write" target="i_check"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="i_fts" target="i_done"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- writes to stores -->
