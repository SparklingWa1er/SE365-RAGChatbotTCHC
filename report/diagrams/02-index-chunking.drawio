<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="index-chunking" name="Index - Chunking">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="QUÁ TRÌNH INDEX &amp; CHUNKING DỮ LIỆU&#10;parse.py (chunk theo section) → fast_ingest.py (embedding song song → 3 store)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="120" y="16" width="840" height="46" as="geometry" />
        </mxCell>

        <!-- containers (behind) -->
        <mxCell id="cParse" value="BƯỚC 1 — PARSE &amp; CHUNKING THEO SECTION (pipeline/parser/parse.py)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#9673A6;dashed=1;verticalAlign=top;fontStyle=1;fontColor=#9673A6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="760" height="430" as="geometry" />
        </mxCell>
        <mxCell id="cIngest" value="BƯỚC 2 — INGEST SONG SONG &amp; EMBEDDING (rag/fast_ingest.py)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6C8EBF;dashed=1;verticalAlign=top;fontStyle=1;fontColor=#6C8EBF;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="800" width="760" height="520" as="geometry" />
        </mxCell>
        <mxCell id="cStore" value="KHO LƯU TRỮ — phục vụ HYBRID RETRIEVAL" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82B366;dashed=1;verticalAlign=top;fontStyle=1;fontColor=#82B366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="1360" width="760" height="160" as="geometry" />
        </mxCell>

        <!-- inputs -->
        <mxCell id="in_raw" value="data/raw/*.json&#10;(5.208 thủ tục thô)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="84" width="170" height="66" as="geometry" />
        </mxCell>
        <mxCell id="in_index" value="data/index.jsonl&#10;(metadata danh sách)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="84" width="170" height="66" as="geometry" />
        </mxCell>

        <!-- PARSE nodes -->
        <mxCell id="p_loadidx" value="load_index(): map id → item&#10;(bổ sung metadata khi detail trống)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="214" width="260" height="48" as="geometry" />
        </mxCell>
        <mxCell id="p_meta" value="extract_meta(): gộp detail + index →&#10;mã thủ tục · tên · lĩnh vực · cấp · cơ quan&#10;· đối tượng · loại · url" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="288" width="260" height="62" as="geometry" />
        </mxCell>
        <mxCell id="p_render" value="Render 8 SECTION sạch (clean / oneline):&#10;Trình tự · Cách thức · Phí, lệ phí · Hồ sơ&#10;Địa chỉ · Điều kiện · Căn cứ pháp lý · Kết quả" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="376" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p_empty" value="Có section&#10;không rỗng?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="470" width="160" height="74" as="geometry" />
        </mxCell>
        <mxCell id="p_skip" value="Bỏ qua&#10;(file rỗng)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="478" width="130" height="56" as="geometry" />
        </mxCell>
        <mxCell id="p_write" value="build_markdown(): YAML frontmatter + thân bài&#10;Sinh chunk theo section: text = &quot;[Tên — Phần]\n&lt;nội dung&gt;&quot; + metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="556" width="260" height="44" as="geometry" />
        </mxCell>

        <!-- corpus outputs (bridge) -->
        <mxCell id="o_md" value="data/corpus/md/&#10;{ma}__{uuid}.md" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="652" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="o_chunks" value="chunks.jsonl&#10;(1 dòng = 1 section)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="652" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="o_meta" value="metadata.jsonl" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="652" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- INGEST nodes -->
        <mxCell id="i_prep" value="Đọc chunks.jsonl → gom theo doc_id&#10;map uuid → .md  ·  bỏ file đã có trong sql.db (resume)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="828" width="300" height="54" as="geometry" />
        </mxCell>
        <mxCell id="i_split" value="split_long_text(): section &gt; 8000 token&#10;→ cắt theo DÒNG, giữ lại tiền tố [Tên — Phần]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="908" width="300" height="56" as="geometry" />
        </mxCell>
        <mxCell id="i_embed" value="embed_batch() — gọi API embedding theo lô 16&#10;(retry khi rate-limit)  →  vector 3072 chiều" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="990" width="300" height="56" as="geometry" />
        </mxCell>
        <mxCell id="ext_azure" value="Azure OpenAI&#10;text-embedding-3-large" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="990" width="130" height="56" as="geometry" />
        </mxCell>
        <mxCell id="i_write" value="Ghi TUẦN TỰ vào store (Phase 2):&#10;• sql.db: 1 source + 2 dòng/chunk (document + vector)&#10;• LanceDB docstore  ·  • Chroma vectorstore&#10;• copy .md → files/index_1/&lt;sha256&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="330" y="1072" width="300" height="86" as="geometry" />
        </mxCell>
        <mxCell id="i_check" value="Checkpoint integrity:&#10;đối chiếu số lượng sql.db ↔ Chroma&#10;↔ LanceDB + kiểm tra HNSW .bin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="1078" width="150" height="74" as="geometry" />
        </mxCell>
        <mxCell id="i_fts" value="Tạo FTS index trên LanceDB&#10;(BM25, tokenizer en_stem)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="1180" width="300" height="48" as="geometry" />
        </mxCell>
        <mxCell id="i_done" value="Hoàn tất index → sẵn sàng truy vấn RAG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="1260" width="300" height="40" as="geometry" />
        </mxCell>

        <!-- STORES -->
        <mxCell id="s_chroma" value="Chroma vectorstore&#10;(vector + HNSW)&#10;→ tìm theo NGỮ NGHĨA" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="1396" width="160" height="92" as="geometry" />
        </mxCell>
        <mxCell id="s_lance" value="LanceDB&#10;docstore + FTS (BM25)&#10;→ tìm theo TỪ KHÓA" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="1396" width="160" height="92" as="geometry" />
        </mxCell>
        <mxCell id="s_sql" value="sql.db&#10;source + quan hệ&#10;(document / vector)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="490" y="1396" width="150" height="92" as="geometry" />
        </mxCell>
        <mxCell id="s_files" value="files/index_1&#10;bản sao .md" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=10;boundedLbl=1;backgroundOutline=1;size=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="1396" width="140" height="92" as="geometry" />
        </mxCell>

        <!-- NOTES -->
        <mxCell id="n_chunk" value="CHIẾN LƯỢC CHUNKING:&#10;cắt theo SECTION (ngữ nghĩa), KHÔNG cắt&#10;cứng theo độ dài. Mỗi chunk tự mang tiền tố&#10;[Tên thủ tục — Tên phần] để không mất ngữ&#10;cảnh khi đứng độc lập lúc truy hồi." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="850" y="350" width="270" height="120" as="geometry" />
        </mxCell>
        <mxCell id="n_batch" value="Lặp cho TOÀN BỘ 5.208 file.&#10;File không có section nào → bỏ qua." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="850" y="490" width="270" height="64" as="geometry" />
        </mxCell>
        <mxCell id="n_parallel" value="SONG SONG: ThreadPoolExecutor 10 worker,&#10;lô 16 chunk/lần gọi → ~15 phút thay vì ~2,5 giờ.&#10;Bypass theflow cache → không treo khi force-kill.&#10;Phase 1 (embed song song) tách Phase 2 (ghi tuần tự)." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="850" y="908" width="290" height="104" as="geometry" />
        </mxCell>
        <mxCell id="n_token" value="Giới hạn embedding 8192 token/input.&#10;Section dài (bảng hồ sơ lớn) bị cắt theo dòng,&#10;giữ ranh giới hàng bảng/bước + lặp tiền tố section&#10;→ tránh lỗi 400 làm mất cả file." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="850" y="1030" width="290" height="98" as="geometry" />
        </mxCell>
        <mxCell id="n_integrity" value="Checkpoint mỗi N file (mặc định 1000):&#10;source = document = vector (sql.db),&#10;Chroma = LanceDB = document, và HNSW&#10;.bin (data_level0/header/length) khác rỗng." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="850" y="1150" width="290" height="98" as="geometry" />
        </mxCell>
        <mxCell id="n_alt" value="(Đường thay thế) ingest_corpus.py nạp .md qua&#10;pipeline kotaemon (FileIndex + TokenSplitter) —&#10;chậm hơn, dùng khi cần đúng pipeline gốc." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=top;size=14;" vertex="1" parent="1">
          <mxGeometry x="850" y="800" width="290" height="80" as="geometry" />
        </mxCell>

        <!-- EDGES -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="in_raw" target="p_loadidx"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="in_index" target="p_loadidx"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="với mỗi file" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="p_loadidx" target="p_meta"><mxGeometry relative="1" as="geometry" /></mxCell>
