        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="p_render" target="p_empty"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="Không" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="p_empty" target="p_skip"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="Có" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;fontSize=10;" edge="1" parent="1" source="p_empty" target="p_write"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;dashed=1;strokeColor=#9673A6;" edge="1" parent="1" source="p_write" target="o_md"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;dashed=1;strokeColor=#9673A6;" edge="1" parent="1" source="p_write" target="o_chunks"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=open;dashed=1;strokeColor=#9673A6;" edge="1" parent="1" source="p_write" target="o_meta"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="o_chunks" target="i_prep"><mxGeometry relative="1" as="geometry" /></mxCell>
