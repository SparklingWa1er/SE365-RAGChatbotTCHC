% Placeholder ẢNH CHỤP MÀN HÌNH (tự thay thế).
%   \screenshotfig{đường-dẫn-ảnh}{mô tả cần chụp gì}{caption}{label}
% - Nếu file ảnh ĐÃ tồn tại  -> tự chèn ảnh (width 86%).
% - Nếu CHƯA có             -> hiện khung gạch nét đứt mô tả nội dung cần chụp.
% Cách dùng: chụp màn hình, lưu vào thư mục img/ ĐÚNG tên gợi ý -> biên dịch lại là ảnh hiện ra.
\newcommand{\screenshotfig}[4]{%
  \begin{figure}[H]\centering
  \IfFileExists{#1}{%
    \includegraphics[width=0.86\textwidth]{#1}%
  }{%
    \begin{tikzpicture}
      \node[draw=black!40, dashed, line width=0.9pt, rounded corners,
            fill=black!4, align=center, inner sep=14pt,
            text width=0.80\textwidth, minimum height=4.3cm] {%
        {\large\bfseries\color{black!55}[\,\ ẢNH CHỤP MÀN HÌNH\ \,]}\\[8pt]
        {\normalsize\color{black!75}#2}\\[12pt]
        {\footnotesize\color{black!45}Lưu ảnh vào: \texttt{\detokenize{#1}}}};
    \end{tikzpicture}%
  }%
  \caption{#3}\label{#4}%
  \end{figure}%
}

% Banner đầu báo cáo: {số tuần}{khoảng ngày}{chủ đề}{màu}{trạng thái}
\newcommand{\weekheader}[5]{%
  \thispagestyle{plain}%
  \noindent\begin{tikzpicture}
    \node[anchor=south west, fill=#4, text=white, rounded corners=3pt, inner sep=9pt,
          text width=\dimexpr\textwidth-18pt\relax] at (0,0) {%
      {\large\textbf{BÁO CÁO TUẦN #1 \textemdash{} #3}}\\[3pt]
      {\small Thời gian: #2 \quad\textbullet\quad Trạng thái: #5}};
  \end{tikzpicture}\par\vspace{5pt}%
  {\small\textit{Trợ lý hỏi đáp thủ tục hành chính công Việt Nam ứng dụng Agentic RAG}}\par
  {\small Nhóm: Nguyễn Xuân Phúc, Nguyễn Minh Triết \hfill GVHD: Đỗ Trọng Hợp, Nguyễn Ngọc Quí}\par
  \vspace{3pt}\hrule\vspace{9pt}%
}
