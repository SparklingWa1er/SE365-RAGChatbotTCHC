# ============================================================
#  .gitignore — chatbot RAG thủ tục hành chính
#  Repo chứa TOÀN BỘ code (gồm thư viện kotaemon đã vendor trong app/libs/).
#  Chỉ KHÔNG chứa: .env, .venv, dữ liệu (data/ + index) — tải từ HuggingFace.
# ============================================================

# --- Bí mật / API key ---
.env
**/.env
*.key

# --- Dữ liệu crawl + corpus + embeddings  (TẢI TỪ HUGGINGFACE) ---
data/raw/
data/pdf/
data/corpus/
data/*.jsonl
data/*.json
data/*.log
data/crawl_state.json
data/failures.jsonl
*.tar.gz
.tmp/

# --- Tài liệu tham khảo / sample ---
references/

# --- Môi trường Python (tạo lại bằng uv khi clone — xem README) ---
.venv/
venv/
env/

# --- Index / cache app sinh ra lúc chạy (KHÔNG commit; index tải từ HF) ---
.theflow/
**/ktem_app_data/
**/user_data/
**/huggingface/
**/vectorstore/
**/docstore/
*.onnx

# --- Python build artifacts (kể cả từ editable install trong app/libs/) ---
__pycache__/
*.py[cod]
*.egg-info/
app/libs/**/build/
*.log

# --- Claude / trợ lý AI ---
.claude/
.claude/**
**/.claude/
CLAUDE.md
CLAUDE.local.md
.claude.json
.mcp.json
.cursor/
.aider*
.continue/

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Frontend React (Node) — chỉ commit source, build lại bằng npm ---
node_modules/
frontend/dist/
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# --- Công cụ dev cục bộ / agent (không thuộc code dự án) ---
.agents/
.playwright-mcp/
skills-lock.json
docs/
sidebar-new.png
#slide
slide_references/
present_content/