# ============================================================
#  Mẫu .env cho kotaemon — chatbot Thủ tục hành chính (tiếng Việt)
#  Copy file này thành kotaemon-app/.env và điền API key của bạn.
#  LLM: Azure OpenAI (gpt-4o) | Embedding: Azure text-embedding-3-large
# ============================================================

# --- Azure OpenAI: LLM sinh câu trả lời ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<YOUR_AZURE_OPENAI_KEY>
OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# --- Azure OpenAI: Embedding (3072 chiều) ---
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-3-large

# --- Tắt OpenAI public (chỉ dùng Azure) ---
OPENAI_API_KEY=

# --- Tắt GraphRAG (không cần, tránh phụ thuộc nặng) ---
USE_GLOBAL_GRAPHRAG=false
USE_NANO_GRAPHRAG=false
USE_LIGHTRAG=false
USE_MS_GRAPHRAG=false
USE_MULTIMODAL=false

# --- Tắt quản lý người dùng (vào thẳng Chat, không login) ---
KH_FEATURE_USER_MANAGEMENT=false

# --- QUAN TRỌNG: Fix hnswlib Unicode path bug trên Windows ---
# Nếu project nằm trong thư mục có tên tiếng Việt / ký tự non-ASCII,
# hnswlib C++ sẽ KHÔNG tạo được file .bin → toàn bộ vector mất sau ingest.
# Đặt KH_APP_DATA_DIR ở đường dẫn ASCII thuần (ví dụ C:\ktem_data).
KH_APP_DATA_DIR=C:\ktem_data
